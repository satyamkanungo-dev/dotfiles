{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "#ff00ff",
          "template": " <#d75f00>{{.Icon}}</> ",
          "options": {
            "alpine": "\uf300",
            "arch": "\uf303",
            "centos": "\uf304",
            "debian": "\uf306",
            "elementary": "\uf309",
            "fedora": "\uf30a",
            "gentoo": "\uf30d",
            "linux": "\ue712",
            "macos": "\ue711",
            "manjaro": "\uf312",
            "mint": "\uf30f",
            "opensuse": "\uf314",
            "raspbian": "\uf315",
            "ubuntu": "\uf31c",
            "windows": "\ue70f"
          }
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#56B6C2",
          "template": " {{ .Path }} ",
          "options": {
            "style": "folder"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#D0666F",
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": true,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 ",
            "fetch_upstream_icon": true
          },
          "template": "<#DDB15F>git:</><#5FAAE8>(</>{{.UpstreamIcon }} {{ .HEAD }}{{ if .Working.Changed }}{{ if .Working.Added }} {{ .Working.Added }}<#00FF00>+</>{{ end }}{{ if .Working.Modified }} {{ .Working.Modified }}<#FFEB3B>!</>{{ end }}{{ if .Working.Deleted }} {{ .Working.Deleted }}<#FF0000>-</>{{ end }}{{ if .Working.Untracked }} {{ .Working.Untracked }}<#FF0000>?</>{{ end }}{{ if .Working.Unmerged }} {{ .Working.Unmerged }}<#FF0000>✖</>{{ end }}{{ end }}{{ if .Staging.Changed }}<#FF9800> ●</>{{ end }}{{ if gt .Ahead 0 }} <#00FF00>{{ .Ahead }}↑</>{{ end }}{{ if gt .Behind 0 }} <#FF0000>{{ .Behind }}↓</>{{ end }}<#5FAAE8>)</>"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": " error",
          "type": "status"
        },
        {
          "foreground": "#FFEB3B",
          "style": "plain",
          "template": " \u276f",

          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
